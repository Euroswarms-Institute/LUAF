# Include docs and license for sdist (PyPI)
include README.md
include LICENSE
include pyproject.toml

# Entry module at repo root
include LUAF.py

# Python package tree (wheels use setuptools package-data + find)
graft luaf

# Optional: include empty or example data so install works
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .env
global-exclude *.log
global-exclude .git
global-exclude .gitignore

# Exclude generated and dev-only content from sdist
prune generated_agents
prune katoolin
prune logs
prune agent_workspace
prune .cursor
prune build
prune dist
prune dist_check
prune dist_check2
prune dist_check3
prune luaf.egg-info
