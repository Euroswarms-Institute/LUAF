# LUAF — copy to .env and fill in. Do not commit .env (secrets).

# Required for trend → spec → agent pipeline
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
SWARMS_API_KEY=sk-your-swarms-api-key-here
SOLANA_PUBKEY=YourSolanaWalletPublicKeyBase58

# Optional: token launch (use one of the two)
# SOLANA_PRIVATE_KEY=your-base58-private-key
# SOLANA_PRIVATE_KEY_FILE=/path/to/file/with/private/key

# Optional: cost tracking (USD per call, for telemetry)
# LUAF_LLM_CALL_COST_USD=0.0
# LUAF_API_CALL_COST_USD=0.0

# Optional: model for generated agent scripts (Agent/toolbox)
# LUAF_AGENT_MODEL=gpt-4.1

# Optional: run LLM test, generated agents output dir
# LUAF_RUN_LLM_TEST=0
# LUAF_GENERATED_AGENTS_DIR=generated_agents

# Optional: X (Twitter) bot — batch-post 2–3 agents per 2-tweet thread (500 tweets/month)
# Get keys from developer.x.com → Project → App → Keys and tokens
# LUAF_POST_TO_X=1
# X_API_KEY=your-api-key
# X_API_SECRET=your-api-secret
# X_ACCESS_TOKEN=your-user-access-token
# X_ACCESS_SECRET=your-user-access-token-secret
# LUAF_X_BATCH_SIZE=2
# LUAF_X_QUEUE_ENABLED=1
